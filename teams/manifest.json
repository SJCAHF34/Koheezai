{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "1.0.0",
  "id": "{{TEAMS_APP_ID}}",
  "developer": {
    "name": "AIDS Healthcare Foundation",
    "websiteUrl": "https://{{APP_DOMAIN}}",
    "privacyUrl": "https://{{APP_DOMAIN}}/privacy",
    "termsOfUseUrl": "https://{{APP_DOMAIN}}/terms"
  },
  "name": {
    "short": "Koheez.ai",
    "full": "Koheez.ai HIV Clinical Decision Support"
  },
  "description": {
    "short": "HIV clinical decision support for AHF pharmacists.",
    "full": "Koheez.ai is a clinical decision support platform for HIV pharmacists, providing drug-interaction checks, patient assessments, consultation notes, and pharmacy operations tools."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#3b82f6",
  "configurableTabs": [
    {
      "configurationUrl": "https://{{APP_DOMAIN}}/teams/config",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupChat"]
    }
  ],
  "staticTabs": [
    {
      "entityId": "koheez-home",
      "name": "Koheez.ai",
      "contentUrl": "https://{{APP_DOMAIN}}/app",
      "websiteUrl": "https://{{APP_DOMAIN}}/app",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["{{APP_DOMAIN}}"],
  "webApplicationInfo": {
    "id": "{{AAD_APP_CLIENT_ID}}",
    "resource": "api://{{APP_DOMAIN}}/{{AAD_APP_CLIENT_ID}}"
  }
}
